{
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm run --dir docs dev",
    "build": "pnpm run --dir docs build",
    "lint": "pnpm run --dir manon lint:css",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "visreg:test": "visreg/scripts/visreg.sh test",
    "visreg:approve": "visreg/scripts/visreg.sh approve",
    "visreg:clean": "docker compose -f visreg/compose.yml run --rm visreg-clean",
    "visreg:report": "visreg/scripts/visreg.sh report"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
